# ─── Phase 2 End-to-End ───────────────────────────────────────────────────────

class TestPhase2E2E:

    def test_full_scan_samples_folder(self, tmp_path):
        from core.phase1 import run_phase1
        from rules.engine import run_phase2
        p1 = run_phase1(str(SAMPLES), verbose=False)
        p2 = run_phase2(p1, output_dir=str(tmp_path), verbose=False)
        assert len(p2.collection) > 0
        assert p2.files_scanned == 3

    def test_output_json_saved(self, tmp_path):
        from core.phase1 import run_phase1
        from rules.engine import run_phase2
        import json
        p1 = run_phase1(str(SAMPLES / "vulnerable.c"), verbose=False)
        p2 = run_phase2(p1, output_dir=str(tmp_path), verbose=False)
        out_file = tmp_path / "vuln_raw.json"
        assert out_file.exists()
        data = json.loads(out_file.read_text())
        assert "vulnerabilities" in data
        assert data["total"] > 0

    def test_summary_keys(self):
        from core.phase1 import run_phase1
        from rules.engine import run_phase2
        p1 = run_phase1(str(SAMPLES), verbose=False)
        p2 = run_phase2(p1, verbose=False)
        s = p2.summary()
        for key in ("total", "critical", "high", "medium", "low", "files_scanned"):
            assert key in s