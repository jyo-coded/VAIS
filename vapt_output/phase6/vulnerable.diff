 /* ── Vuln 1: Buffer overflow via strcpy ── */

 void greet_user(char *name) {

     char buffer[64];

-    strcpy(buffer, name);          /* CWE-120: no bounds check */

+    strncpy(buffer, name, sizeof(buffer) - 1);

